# ─── Agent / Contract Deployer ───────────────────────────────────────────────
# Your private key (NEVER commit the real key — this file is safe to commit)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# The AI agent wallet address (can be same as deployer for testing)
AGENT_ADDRESS=0x_AGENT_WALLET_ADDRESS

# ─── Contract Addresses (filled after: forge script script/Deploy.s.sol ...) ─
PAYROLL_VAULT_ADDRESS=0x_FILL_AFTER_DEPLOY
PAYROLL_SCHEDULER_ADDRESS=0x_FILL_AFTER_DEPLOY

# Yield source addresses (set by Deploy.s.sol — update if you add real sources)
YIELD_SOURCE_A=0xA11CE0000000000000000000000000000000000A
YIELD_SOURCE_B=0xB0B0000000000000000000000000000000000B0B

# ─── LLM (Anthropic) ─────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-_YOUR_KEY_HERE

# LLM model (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# ─── Chain / RPC ─────────────────────────────────────────────────────────────
# Chain ID: 84532 = Base Sepolia testnet (use for demo), 8453 = Base mainnet
CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org

# ─── x402 Yield Server ───────────────────────────────────────────────────────
# The wallet address that receives $0.001 USDC per yield data request
WALLET_ADDRESS=0x_YOUR_RECEIVING_WALLET

# Port the local yield server listens on
SERVER_PORT=4021

# Where the agent connects to fetch yield data
YIELD_SERVER_URL=http://localhost:4021

# x402 facilitator endpoint (testnet default — use x402.org/facilitator for testnet)
X402_FACILITATOR_URL=https://x402.org/facilitator

# ─── Frontend (Next.js public vars) ──────────────────────────────────────────
# Create a Privy app at: https://privy.io — copy the App ID here
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

NEXT_PUBLIC_PAYROLL_VAULT_ADDRESS=0x_FILL_AFTER_DEPLOY
NEXT_PUBLIC_PAYROLL_SCHEDULER_ADDRESS=0x_FILL_AFTER_DEPLOY
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org

# ─── Block Explorer (contract verification) ──────────────────────────────────
# Get free API key at: https://basescan.org/apis
BASESCAN_API_KEY=your-basescan-api-key
