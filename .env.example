# ─── Agent / Contract Deployer ─────────────────────────────────────────────
# Your private key (never commit the real key)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# The AI agent wallet address (can be same as deployer for testing)
AGENT_ADDRESS=0x_AGENT_WALLET_ADDRESS

# ─── Contract Addresses (filled after deploy) ───────────────────────────────
PAYROLL_VAULT_ADDRESS=0x_AFTER_DEPLOY
PAYROLL_SCHEDULER_ADDRESS=0x_AFTER_DEPLOY

# Yield source addresses (set by Deploy.s.sol — update if you add real sources)
YIELD_SOURCE_A=0xA11CE0000000000000000000000000000000000A
YIELD_SOURCE_B=0xB0B0000000000000000000000000000000000B0B

# ─── LLM (Anthropic or Alibaba Cloud DashScope) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-_YOUR_KEY_HERE

# Alibaba Cloud DashScope (optional — for Pharos sponsor track)
# DASHSCOPE_API_KEY=sk-_YOUR_DASHSCOPE_KEY

# LLM model to use (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# ─── Chain / RPC ─────────────────────────────────────────────────────────────
# Chain ID: 84532 = Base Sepolia, 8453 = Base Mainnet
CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org

# ─── x402 Server ─────────────────────────────────────────────────────────────
# The address that receives x402 micropayments for yield data
WALLET_ADDRESS=0x_YOUR_RECEIVING_WALLET

# x402 yield server URL (default: localhost)
YIELD_SERVER_URL=http://localhost:4021

# x402 facilitator (testnet default)
X402_FACILITATOR_URL=https://x402.org/facilitator

# ─── Frontend (Next.js public vars) ─────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
NEXT_PUBLIC_PAYROLL_VAULT_ADDRESS=0x_AFTER_DEPLOY
NEXT_PUBLIC_PAYROLL_SCHEDULER_ADDRESS=0x_AFTER_DEPLOY
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org

# ─── Block Explorer ──────────────────────────────────────────────────────────
BASESCAN_API_KEY=your-basescan-api-key

# ─── Optional: Server port ───────────────────────────────────────────────────
SERVER_PORT=4021
